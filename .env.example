# UpNews Infrastructure Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration
# ============================================================================

# Development: Local SQLite
DATABASE_URL=sqlite:///./data/upnews.db

# Production: Turso Edge SQLite (uncomment to use)
# DATABASE_URL=libsql://upnews-db.turso.io
# TURSO_URL=libsql://upnews-db.turso.io
# TURSO_TOKEN=your-auth-token-here

# ============================================================================
# API Service Configuration (upnews-api)
# ============================================================================

# Server binding
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=info

# CORS settings (for frontend requests)
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,https://upnews.com

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# Pipeline Service Configuration (upnews-pipeline)
# ============================================================================

# Crawl scheduling
CRAWL_INTERVAL_HOURS=4

# ML Model selection
ML_MODEL=distilbert-base-uncased

# Feed processing
MAX_ARTICLES_PER_FEED=50
FEED_TIMEOUT_SECONDS=10
MAX_CONCURRENT_FEEDS=5

# Article filtering
MIN_ARTICLE_LENGTH=100
LANGUAGE=en

# ============================================================================
# Frontend Configuration (upnews-frontend)
# ============================================================================

# API endpoint (where frontend talks to backend)
REACT_APP_API_URL=http://localhost:8000
# For production:
# REACT_APP_API_URL=https://api.upnews.com

# Analytics (optional)
REACT_APP_GA_ID=
REACT_APP_SENTRY_DSN=

# Feature flags
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_EXPORT=false

# ============================================================================
# Monitoring & Alerting
# ============================================================================

# Healthchecks.io (pipeline health)
HEALTHCHECKS_CRAWL_URL=https://hc-ping.com/your-uuid-here
HEALTHCHECKS_CRAWL_URL_FAIL=https://hc-ping.com/your-uuid-here/fail

# UptimeRobot (API uptime)
UPTIMEROBOT_API_KEY=

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts

# Email alerts
ALERT_EMAIL=ops@upnews.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@upnews.com
SMTP_PASSWORD=

# ============================================================================
# Deployment Configuration
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Fly.io (if using)
FLY_APP_NAME=upnews-platform
FLY_REGION=iad

# Render (if using)
RENDER_DEPLOY_HOOK=

# Cloudflare Pages (if using)
CF_PAGES_PROJECT=upnews-frontend
CF_ZONE_ID=

# ============================================================================
# Development Only
# ============================================================================

# Disable in production
DEBUG=false
CORS_ALLOW_CREDENTIALS=false

# Seed data for testing
SEED_FEEDS=true
SEED_ARTICLES=true

# Performance profiling
ENABLE_PROFILING=false
